# Theme
THEME_KEY="indigone"

# Git credentials used by Git based apps like Decap Admin
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# AI provider — Mistral AI (OpenAI-compatible, works from Algeria)
# Get your key at: https://console.mistral.ai/api-keys
AI_PROVIDER=openai
GPT_API_KEY=your-mistral-api-key-here
GPT_BASE_URL=https://api.mistral.ai/v1
GPT_MODEL_NAME=mistral-small-latest

# Alternatively use OpenAI:
# AI_PROVIDER=openai
# GPT_API_KEY=sk-...
# GPT_BASE_URL=
# GPT_MODEL_NAME=gpt-4o-mini

MAX_ARTICLE_NUMS=20

RSS_CACHE_ENABLE=true

# gittalk comment
GITTALK_CLIENT_ID=""
GITTALK_CLIENT_SECRET=""
GITTALK_REPO=""
GITTALK_OWNER=""

CZ_API_KEY=