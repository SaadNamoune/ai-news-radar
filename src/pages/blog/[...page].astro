---
export const prerender = true;

import { getCollection } from "astro:content";
import DefaultPageLayout from "$/layouts/default.astro";
import PostPreviewList from "$/components/PostPreviewList.astro";
import Paginator from "$/components/Paginator.astro";
import { PAGE_SIZE } from "$/config";

export async function getStaticPaths({ paginate }) {
  const allPosts = await getCollection("blog");
  const sorted = allPosts.sort(
    (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
  );
  return paginate(sorted, { pageSize: PAGE_SIZE });
}

const { page } = Astro.props;
const isFirstPage = page.currentPage === 1;
---

<DefaultPageLayout
  content={{
    title: "Digest Archive",
    description: `${page.total} issues — automated daily digest of AI, CS research, cybersecurity and open-source.`,
  }}
>
  <PostPreviewList
    posts={page.data}
    mode="row"
    showFeatured={isFirstPage}
  />
  <Paginator page={page} />
</DefaultPageLayout>
