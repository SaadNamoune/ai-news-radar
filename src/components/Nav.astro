---
import { toTitleCase } from "$/utils";
import { NAV_ITEMS } from "$/config";
---

<nav class="site-nav" aria-label="Main navigation" transition:animate="fade">
  <ul class="site-nav__list">
    {
      Object.keys(NAV_ITEMS).map((navItemKey) => (
        <li>
          <a
            class:list={[
              "site-nav__link",
              Astro.url.pathname === NAV_ITEMS[navItemKey].path
                ? "site-nav__link--active"
                : "site-nav__link--default",
            ]}
            href={NAV_ITEMS[navItemKey].path}
            title={NAV_ITEMS[navItemKey].title}
          >
            {toTitleCase(NAV_ITEMS[navItemKey].title)}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .site-nav {
    @apply py-3;
  }
  .site-nav__list {
    @apply flex flex-wrap gap-0 list-none;
  }
  .site-nav__link {
    @apply block px-3 py-1.5 text-sm font-medium no-underline rounded-md transition-colors duration-150;
  }
  .site-nav__link--active {
    color: #0284c7;
    background: #f0f9ff;
    font-weight: 600;
  }
  html.dark .site-nav__link--active {
    color: #38bdf8;
    background: rgba(56, 189, 248, 0.08);
  }
  .site-nav__link--default {
    color: #6b7280;
  }
  html.dark .site-nav__link--default { color: #64748b; }
  .site-nav__link--default:hover {
    color: #1e293b;
    background: #f1f5f9;
  }
  html.dark .site-nav__link--default:hover {
    color: #e2e8f0;
    background: #1e293b;
  }
</style>
