---
import { toTitleCase } from "$/utils";
import { NAV_ITEMS } from "$/config";
---

<nav class="nav" transition:animate="fade">
  <ul class="nav-list">
    {
      Object.keys(NAV_ITEMS).map((navItemKey) => (
        <li>
          <a
            class:list={[
              "nav-item",
              Astro.url.pathname === NAV_ITEMS[navItemKey].path
                ? "nav-item--active"
                : "nav-item--default",
            ]}
            href={NAV_ITEMS[navItemKey].path}
            title={NAV_ITEMS[navItemKey].title}
          >
            {toTitleCase(NAV_ITEMS[navItemKey].title)}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .nav {
    @apply py-3;
  }
  .nav-list {
    @apply inline-flex list-none gap-1 flex-wrap;
  }
  .nav-item {
    @apply px-3.5 py-1.5 rounded-full text-sm font-semibold transition-all duration-200 no-underline;
  }
  .nav-item--active {
    background: rgba(99, 102, 241, 0.1);
    color: #6366f1;
  }
  html.dark .nav-item--active {
    background: rgba(129, 140, 248, 0.12);
    color: #818cf8;
  }
  .nav-item--default {
    @apply text-gray-500 dark:text-gray-500;
  }
  .nav-item--default:hover {
    background: rgba(0, 0, 0, 0.04);
    color: #374151;
  }
  html.dark .nav-item--default:hover {
    background: rgba(255, 255, 255, 0.05);
    color: #d1d5db;
  }
</style>
