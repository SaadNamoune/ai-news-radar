---
import { toTitleCase } from "$/utils";
import { NAV_ITEMS } from "$/config";
---

<nav class="site-nav" aria-label="Main navigation" transition:animate="fade">
  <ul class="site-nav__list">
    {
      Object.keys(NAV_ITEMS).map((key) => (
        <li>
          <a
            class:list={[
              "site-nav__link",
              Astro.url.pathname === NAV_ITEMS[key].path && "site-nav__link--active",
            ]}
            href={NAV_ITEMS[key].path}
          >
            {toTitleCase(NAV_ITEMS[key].title)}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .site-nav {
    padding: 0.25rem 0 0.75rem;
  }
  .site-nav__list {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .site-nav__link {
    display: block;
    padding: 0.375rem 0.75rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-decoration: none;
    border-radius: 0.25rem;
    transition: background 0.15s, color 0.15s;
    color: var(--text-2);
  }
  .site-nav__link:first-child { padding-left: 0; }
  .site-nav__link--active {
    color: var(--accent);
    font-weight: 700;
  }
  .site-nav__link:not(.site-nav__link--active):hover {
    background: var(--bg-alt);
    color: var(--text);
  }
</style>
