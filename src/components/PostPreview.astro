---
import type { CollectionEntry } from "astro:content";
import { getMonthName } from "$/utils";

interface Props {
  post: CollectionEntry<"blog">;
  asCard?: boolean;
  featured?: boolean;
}

const {
  post: { data: post, slug },
  asCard = false,
  featured = false,
} = Astro.props;

const postDate = new Date(post.date);
const day    = String(postDate.getDate()).padStart(2, "0");
const month  = getMonthName(post.date).slice(0, 3).toUpperCase();
const year   = postDate.getFullYear();
const tags   = (post.tags || []).slice(0, 5);
const shortDate = `${month} ${day}, ${year}`;
---

{featured ? (
  <!-- Featured / Hero card -->
  <a href={`/blog/${slug}`} class="featured-card" title={post.title}>
    <div class="featured-card__inner">
      <div class="featured-card__kicker">
        <span class="featured-kicker-label">LATEST ISSUE</span>
        <span class="featured-kicker-date">{shortDate}</span>
      </div>
      <h2 class="featured-card__title">{post.title}</h2>
      {tags.length > 0 && (
        <div class="featured-card__tags">
          {tags.map(t => <span class="ftag">{t}</span>)}
        </div>
      )}
      <p class="featured-card__desc">{post.description}</p>
      <span class="featured-card__cta">Read issue <span aria-hidden="true">→</span></span>
    </div>
  </a>
) : (
  <!-- Standard card -->
  <a href={`/blog/${slug}`} class:list={["issue-card", asCard && "issue-card--grid"]} title={post.title}>
    <div class="issue-card__date">{shortDate}</div>
    <h4 class="issue-card__title">{post.title}</h4>
    {tags.length > 0 && (
      <div class="issue-card__tags">
        {tags.slice(0,3).map(t => <span class="tag">{t}</span>)}
      </div>
    )}
    <span class="issue-card__read">Read <span aria-hidden="true">→</span></span>
  </a>
)}

<style>
  /* ═══ Featured card ═══ */
  .featured-card {
    display: block;
    text-decoration: none;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    transition: border-color 0.2s, box-shadow 0.2s;
    overflow: hidden;
  }
  .featured-card:hover {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-bg);
  }
  .featured-card__inner {
    padding: 1.75rem 2rem;
  }
  .featured-card__kicker {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.875rem;
  }
  .featured-kicker-label {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-bg);
    border: 1px solid var(--accent);
    padding: 0.2em 0.6em;
    border-radius: 0.25rem;
    opacity: 0.9;
  }
  .featured-kicker-date {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-3);
    font-variant-numeric: tabular-nums;
  }
  .featured-card__title {
    font-size: clamp(1.25rem, 3vw, 1.625rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: var(--text);
    line-height: 1.25;
    margin-bottom: 0.875rem;
    transition: color 0.15s;
  }
  .featured-card:hover .featured-card__title { color: var(--accent); }
  .featured-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: 0.875rem;
  }
  .ftag {
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.2em 0.55em;
    border-radius: 0.25rem;
    background: var(--bg-alt);
    color: var(--text-2);
    border: 1px solid var(--border);
    font-family: 'SFMono-Regular', Consolas, Menlo, monospace;
    letter-spacing: 0.02em;
  }
  .featured-card__desc {
    font-size: 0.875rem;
    color: var(--text-2);
    line-height: 1.6;
    margin-bottom: 1.25rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .featured-card__cta {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.01em;
  }

  /* ═══ Standard issue card ═══ */
  .issue-card {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding: 1.125rem 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    text-decoration: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    cursor: pointer;
  }
  .issue-card:hover {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-bg);
  }
  .issue-card__date {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--accent);
    font-variant-numeric: tabular-nums;
  }
  .issue-card__title {
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--text);
    line-height: 1.35;
    transition: color 0.15s;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .issue-card:hover .issue-card__title { color: var(--accent); }
  .issue-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin-top: 0.125rem;
  }
  .tag {
    font-size: 0.62rem;
    font-weight: 500;
    padding: 0.15em 0.45em;
    border-radius: 0.2rem;
    background: var(--bg-alt);
    color: var(--text-3);
    border: 1px solid var(--border-alt);
    font-family: 'SFMono-Regular', Consolas, Menlo, monospace;
  }
  .issue-card__read {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--accent);
    margin-top: 0.375rem;
    opacity: 0;
    transition: opacity 0.15s;
  }
  .issue-card:hover .issue-card__read { opacity: 1; }
</style>
