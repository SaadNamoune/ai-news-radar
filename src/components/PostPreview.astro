---
import type { CollectionEntry } from "astro:content";
import { getMonthName } from "$/utils";

interface Props {
  post: CollectionEntry<"blog">;
  asCard?: boolean;
}

const {
  post: { data: post, slug },
  asCard = false,
} = Astro.props;

const postDate = new Date(post.date);
const day = String(postDate.getDate()).padStart(2, "0");
const month = getMonthName(post.date).slice(0, 3);
const year = postDate.getFullYear();
const formattedDate = `${month} ${day}, ${year}`;
const tags = (post.tags || []).slice(0, 5);
---

<a
  href={`/${"blog"}/${slug}`}
  class:list={["digest-card", asCard && "digest-card--grid"]}
  title={post.title}
>
  <div class="digest-card__inner">
    <div class="digest-card__header">
      <h4 class="digest-card__title">{post.title}</h4>
      <span class="digest-card__date">{formattedDate}</span>
    </div>

    {
      tags.length > 0 && (
        <div class="digest-card__tags">
          {tags.map((tag) => (
            <span class="tag-chip">{tag}</span>
          ))}
        </div>
      )
    }

    <p class="digest-card__desc">{post.description}</p>

    <span class="digest-card__read">Read digest →</span>
  </div>
</a>

<style>
  .digest-card {
    @apply block no-underline rounded-xl transition-all duration-200;
    background: #ffffff;
    border: 1px solid #e5e7eb;
    text-decoration: none !important;
  }
  html.dark .digest-card {
    background: #1e293b;
    border-color: #334155;
  }
  .digest-card:hover {
    border-color: #bae6fd;
    box-shadow: 0 4px 16px rgba(2, 132, 199, 0.08);
  }
  html.dark .digest-card:hover {
    border-color: #0369a1;
    box-shadow: 0 4px 20px rgba(2, 132, 199, 0.15);
  }

  .digest-card--grid {
    @apply w-full sm:w-72;
  }

  .digest-card__inner {
    @apply p-4 sm:p-5;
  }

  /* Header row: title + date */
  .digest-card__header {
    @apply flex items-start justify-between gap-3 mb-2;
  }
  .digest-card__title {
    @apply text-sm font-bold leading-snug flex-1;
    color: #0f172a;
    transition: color 0.15s;
  }
  html.dark .digest-card__title { color: #f1f5f9; }
  .digest-card:hover .digest-card__title { color: #0284c7; }
  html.dark .digest-card:hover .digest-card__title { color: #38bdf8; }

  .digest-card__date {
    @apply text-xs flex-none font-medium tabular-nums;
    color: #94a3b8;
    white-space: nowrap;
  }
  html.dark .digest-card__date { color: #475569; }

  /* Tag chips */
  .digest-card__tags {
    @apply flex flex-wrap gap-1 mb-2;
  }
  .tag-chip {
    @apply inline-block text-xs px-1.5 py-0.5 rounded;
    background: #f1f5f9;
    color: #475569;
    font-family: 'SFMono-Regular', Consolas, Menlo, monospace;
    border: 1px solid #e2e8f0;
    font-size: 0.7rem;
  }
  html.dark .tag-chip {
    background: #0f172a;
    color: #64748b;
    border-color: #1e293b;
  }

  /* Description */
  .digest-card__desc {
    @apply text-xs leading-relaxed line-clamp-2 mb-3;
    color: #6b7280;
  }
  html.dark .digest-card__desc { color: #64748b; }

  /* Read link */
  .digest-card__read {
    @apply text-xs font-semibold;
    color: #0284c7;
    opacity: 0;
    transition: opacity 0.15s;
  }
  html.dark .digest-card__read { color: #38bdf8; }
  .digest-card:hover .digest-card__read { opacity: 1; }

  /* Responsive: on mobile, make date go below title */
  @media (max-width: 480px) {
    .digest-card__header {
      @apply flex-col gap-1;
    }
  }
</style>
