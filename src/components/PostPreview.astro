---
import type { CollectionEntry } from "astro:content";
import { getMonthName } from "$/utils";

interface Props {
  post: CollectionEntry<"blog">;
  asCard?: boolean;
  featured?: boolean;
}

const {
  post: { data: post, slug },
  asCard = false,
  featured = false,
} = Astro.props;

const postDate = new Date(post.date);
const day    = String(postDate.getDate()).padStart(2, "0");
const month  = getMonthName(post.date).slice(0, 3).toUpperCase();
const year   = postDate.getFullYear();
const tags   = (post.tags || []).slice(0, 6);
const shortDate = `${month} ${day}, ${year}`;
const paperCount = (post.description?.match(/·/g) || []).length + 1;
---

{featured ? (
  <a href={`/blog/${slug}`} class="hero-card" title={post.title}>
    <div class="hero-card__accent"></div>
    <div class="hero-card__body">
      <div class="hero-card__top">
        <div class="hero-card__meta">
          <span class="hero-badge">LATEST ISSUE</span>
          <time class="hero-date" datetime={post.date}>{shortDate}</time>
        </div>
        <div class="hero-card__cta">Read issue →</div>
      </div>
      <h2 class="hero-card__title">{post.title}</h2>
      {post.description && (
        <p class="hero-card__desc">{post.description}</p>
      )}
      <div class="hero-card__footer">
        <div class="hero-card__tags">
          {tags.map(t => <span class="hero-tag">{t}</span>)}
        </div>
        <span class="hero-count">{paperCount} papers</span>
      </div>
    </div>
  </a>
) : (
  <a href={`/blog/${slug}`} class="issue-card" title={post.title}>
    <div class="issue-card__header">
      <time class="issue-card__date">{shortDate}</time>
      <span class="issue-card__arrow">→</span>
    </div>
    <h4 class="issue-card__title">{post.title}</h4>
    {tags.length > 0 && (
      <div class="issue-card__tags">
        {tags.slice(0,4).map(t => <span class="tag">{t}</span>)}
      </div>
    )}
  </a>
)}

<style>
  /* ══════════════════════════════
     HERO / FEATURED CARD
  ══════════════════════════════ */
  .hero-card {
    display: flex;
    text-decoration: none;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 0.625rem;
    overflow: hidden;
    transition: box-shadow 0.2s, border-color 0.2s;
    position: relative;
  }
  .hero-card:hover {
    border-color: var(--accent);
    box-shadow: 0 4px 24px rgba(2,132,199,0.1), 0 1px 4px rgba(0,0,0,0.06);
  }

  .hero-card__accent {
    width: 4px;
    flex-shrink: 0;
    background: linear-gradient(180deg, #0284c7 0%, #38bdf8 100%);
  }

  .hero-card__body {
    flex: 1;
    padding: 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .hero-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .hero-card__meta {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }
  .hero-badge {
    font-size: 0.58rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-bg);
    border: 1px solid var(--accent);
    padding: 0.2em 0.65em;
    border-radius: 0.25rem;
  }
  .hero-date {
    font-size: 0.75rem;
    color: var(--text-3);
    font-variant-numeric: tabular-nums;
    font-weight: 500;
  }
  .hero-card__cta {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--accent);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.15s, transform 0.15s;
  }
  .hero-card:hover .hero-card__cta { opacity: 1; transform: translateX(0); }

  .hero-card__title {
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    color: var(--text);
    line-height: 1.2;
    transition: color 0.15s;
  }
  .hero-card:hover .hero-card__title { color: var(--accent); }

  .hero-card__desc {
    font-size: 0.85rem;
    color: var(--text-2);
    line-height: 1.65;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .hero-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.25rem;
  }
  .hero-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    flex: 1;
    min-width: 0;
  }
  .hero-tag {
    font-size: 0.62rem;
    font-weight: 600;
    padding: 0.2em 0.5em;
    border-radius: 0.2rem;
    background: var(--bg-alt);
    color: var(--text-3);
    border: 1px solid var(--border-alt);
    font-family: 'SFMono-Regular', Consolas, Menlo, monospace;
    white-space: nowrap;
  }
  .hero-count {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--text-3);
    white-space: nowrap;
    margin-left: 0.75rem;
    flex-shrink: 0;
    background: var(--bg-alt);
    border: 1px solid var(--border);
    padding: 0.2em 0.6em;
    border-radius: 0.25rem;
  }

  /* ══════════════════════════════
     STANDARD ISSUE CARD
  ══════════════════════════════ */
  .issue-card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1rem 1.125rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    text-decoration: none;
    transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
    cursor: pointer;
  }
  .issue-card:hover {
    border-color: var(--accent);
    box-shadow: 0 4px 16px rgba(2,132,199,0.08);
    transform: translateY(-1px);
  }
  .issue-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .issue-card__date {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--accent);
    font-variant-numeric: tabular-nums;
    text-transform: uppercase;
  }
  .issue-card__arrow {
    font-size: 0.85rem;
    color: var(--text-3);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.15s, transform 0.15s;
  }
  .issue-card:hover .issue-card__arrow { opacity: 1; transform: translateX(0); }

  .issue-card__title {
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--text);
    line-height: 1.4;
    transition: color 0.15s;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .issue-card:hover .issue-card__title { color: var(--accent); }

  .issue-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin-top: 0.1rem;
  }
  .tag {
    font-size: 0.6rem;
    font-weight: 500;
    padding: 0.15em 0.4em;
    border-radius: 0.2rem;
    background: var(--bg-alt);
    color: var(--text-3);
    border: 1px solid var(--border-alt);
    font-family: 'SFMono-Regular', Consolas, Menlo, monospace;
  }
</style>
