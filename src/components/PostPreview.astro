---
import type { CollectionEntry } from "astro:content";
import { getMonthName } from "$/utils";

interface Props {
  post: CollectionEntry<"blog">;
  asCard?: boolean;
}

const {
  post: { data: post, slug },
  asCard = false,
} = Astro.props;

const postDate = new Date(post.date);
const day = postDate.getDate();
const month = getMonthName(post.date).slice(0, 3).toUpperCase();
const year = postDate.getFullYear();
const tags = (post.tags || []).slice(0, 4);
---

<a
  href={`/${"blog"}/${slug}`}
  class:list={["post-card", asCard && "post-card--grid"]}
  title={post.title}
>
  <div class="post-card__date" aria-label={`${day} ${month} ${year}`}>
    <span class="date-day">{day}</span>
    <span class="date-month">{month}</span>
    <span class="date-year">{year}</span>
  </div>

  <div class="post-card__body">
    <h4 class="post-card__title">{post.title}</h4>
    {
      tags.length > 0 && (
        <div class="post-card__tags">
          {tags.map((tag) => (
            <span class="tag-pill">{tag}</span>
          ))}
        </div>
      )
    }
    <p class="post-card__desc">{post.description}</p>
  </div>

  <span class="post-card__arrow" aria-hidden="true">→</span>
</a>

<style>
  .post-card {
    @apply flex items-start gap-5 p-5 rounded-2xl no-underline cursor-pointer;
    background: rgba(255, 255, 255, 0.8);
    border: 1px solid rgba(0, 0, 0, 0.07);
    transition: border-color 0.25s, box-shadow 0.25s, background 0.25s;
    text-decoration: none !important;
  }
  html.dark .post-card {
    background: rgba(255, 255, 255, 0.025);
    border-color: rgba(255, 255, 255, 0.06);
  }
  .post-card:hover {
    border-color: rgba(99, 102, 241, 0.35);
    box-shadow: 0 8px 32px rgba(99, 102, 241, 0.08);
    background: white;
  }
  html.dark .post-card:hover {
    border-color: rgba(129, 140, 248, 0.3);
    box-shadow: 0 8px 32px rgba(99, 102, 241, 0.12);
    background: rgba(255, 255, 255, 0.04);
  }

  .post-card--grid {
    @apply flex-col sm:w-72 md:w-64;
  }

  /* Date badge */
  .post-card__date {
    @apply flex-none flex flex-col items-center text-center w-11 pt-0.5;
  }
  .post-card--grid .post-card__date {
    @apply flex-row items-baseline gap-1.5 w-full;
  }
  .date-day {
    @apply text-3xl font-black leading-none;
    color: #6366f1;
  }
  html.dark .date-day {
    color: #818cf8;
  }
  .post-card--grid .date-day {
    @apply text-2xl;
  }
  .date-month {
    @apply text-xs tracking-wider font-bold;
    color: #9ca3af;
    margin-top: 2px;
  }
  html.dark .date-month {
    color: #6b7280;
  }
  .date-year {
    @apply text-xs;
    color: #d1d5db;
  }
  html.dark .date-year {
    color: #374151;
  }

  /* Body */
  .post-card__body {
    @apply flex-1 min-w-0;
  }
  .post-card__title {
    @apply text-sm font-bold leading-snug mb-1.5;
    color: #111827;
    transition: color 0.15s;
  }
  html.dark .post-card__title {
    color: #f1f5f9;
  }
  .post-card:hover .post-card__title {
    color: #6366f1;
  }
  html.dark .post-card:hover .post-card__title {
    color: #818cf8;
  }

  /* Tags */
  .post-card__tags {
    @apply flex flex-wrap gap-1 mb-2;
  }
  .tag-pill {
    @apply inline-block px-2 py-0.5 rounded-md text-xs font-medium;
    background: rgba(99, 102, 241, 0.08);
    color: #6366f1;
    border: 1px solid rgba(99, 102, 241, 0.12);
  }
  html.dark .tag-pill {
    background: rgba(129, 140, 248, 0.1);
    color: #a5b4fc;
    border-color: rgba(129, 140, 248, 0.15);
  }

  /* Description */
  .post-card__desc {
    @apply text-xs leading-relaxed line-clamp-2;
    color: #6b7280;
  }
  html.dark .post-card__desc {
    color: #6b7280;
  }

  /* Arrow */
  .post-card__arrow {
    @apply flex-none text-base mt-0.5;
    color: #e5e7eb;
    transition: color 0.2s, transform 0.2s;
  }
  html.dark .post-card__arrow {
    color: #374151;
  }
  .post-card:hover .post-card__arrow {
    color: #6366f1;
    transform: translateX(3px);
  }
  html.dark .post-card:hover .post-card__arrow {
    color: #818cf8;
  }
</style>
