---
import { SITE } from "$/config";
import ModeLabel from "./ModeLabel.svelte";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__left">
      <span class="site-footer__brand">{SITE.name}</span>
      <span class="site-footer__sep">·</span>
      <span class="site-footer__copy">&copy; {year} {SITE.author}</span>
    </div>

    <div class="site-footer__right">
      <a href="/blog" class="footer-link">Archives</a>
      <a href="/tags" class="footer-link">Tags</a>
      <a href="/about" class="footer-link">About</a>
      <a href="/rss.xml" class="footer-link">RSS</a>
      <span class="site-footer__sep">·</span>
      <span class="site-footer__mode"><ModeLabel client:load /></span>
      <span class="site-footer__sep">·</span>
      <a href="https://astro.build/" class="footer-link" target="_blank" rel="noopener">Astro</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    @apply pt-6 pb-8 mt-12;
    border-top: 1px solid #e5e7eb;
  }
  html.dark .site-footer { border-top-color: #1e293b; }

  .site-footer__inner {
    @apply flex flex-wrap justify-between items-center gap-3;
  }

  .site-footer__left {
    @apply flex items-center gap-2 text-sm;
    color: #94a3b8;
  }
  html.dark .site-footer__left { color: #475569; }

  .site-footer__brand {
    font-weight: 700;
    color: #64748b;
  }
  html.dark .site-footer__brand { color: #334155; }

  .site-footer__sep { color: #d1d5db; }
  html.dark .site-footer__sep { color: #1e293b; }

  .site-footer__right {
    @apply flex flex-wrap items-center gap-2 text-xs;
    color: #94a3b8;
  }
  html.dark .site-footer__right { color: #475569; }

  .footer-link {
    text-decoration: none;
    color: #94a3b8;
    transition: color 0.15s;
  }
  html.dark .footer-link { color: #475569; }
  .footer-link:hover { color: #0284c7; }
  html.dark .footer-link:hover { color: #38bdf8; }

  .site-footer__mode { color: #94a3b8; }
  html.dark .site-footer__mode { color: #475569; }

  /* Stack on very small screens */
  @media (max-width: 480px) {
    .site-footer__inner { @apply flex-col items-start; }
    .site-footer__right { @apply gap-2; }
  }
</style>
