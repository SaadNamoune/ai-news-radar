---
import { SITE } from "$/config";
import ModeLabel from "./ModeLabel.svelte";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__top">
    <div class="site-footer__brand">
      <span class="site-footer__name">{SITE.name.toUpperCase()}</span>
      <p class="site-footer__desc">
        Daily digest of AI research, cybersecurity, distributed systems
        and computer science — curated automatically by Mistral AI.
      </p>
    </div>

    <div class="site-footer__cols">
      <div class="site-footer__col">
        <h4 class="site-footer__col-title">Navigate</h4>
        <ul>
          <li><a href="/" class="site-footer__link">Today's Digest</a></li>
          <li><a href="/blog" class="site-footer__link">All Issues</a></li>
          <li><a href="/tags" class="site-footer__link">Topics</a></li>
          <li><a href="/about" class="site-footer__link">About</a></li>
        </ul>
      </div>
      <div class="site-footer__col">
        <h4 class="site-footer__col-title">Sources</h4>
        <ul>
          <li><span class="site-footer__src">arXiv cs.LG · cs.AI · cs.CR</span></li>
          <li><span class="site-footer__src">HuggingFace Daily Papers</span></li>
          <li><span class="site-footer__src">Krebs · Schneier on Security</span></li>
          <li><span class="site-footer__src">DeepMind · Meta AI · BAIR</span></li>
        </ul>
      </div>
      <div class="site-footer__col">
        <h4 class="site-footer__col-title">Connect</h4>
        <ul>
          <li><a href={SITE.githubUrl} class="site-footer__link" target="_blank" rel="noopener">GitHub Repository</a></li>
          <li><a href="/rss.xml" class="site-footer__link">RSS Feed</a></li>
          <li><span class="site-footer__src">{SITE.author}</span></li>
          <li><span class="site-footer__src">{SITE.authorBio}</span></li>
        </ul>
      </div>
    </div>
  </div>

  <div class="site-footer__bottom">
    <span>&copy; {year} {SITE.author} · All rights reserved</span>
    <span class="site-footer__bottom-mid">
      <ModeLabel client:load /> mode
      &middot;
      Built with <a href="https://astro.build/" class="site-footer__link" target="_blank" rel="noopener">Astro</a>
      &middot;
      Powered by <a href="https://mistral.ai/" class="site-footer__link" target="_blank" rel="noopener">Mistral AI</a>
    </span>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 4rem;
    border-top: 2px solid var(--text);
    padding-top: 2rem;
    padding-bottom: 2rem;
  }

  .site-footer__top {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 2rem;
  }
  @media (min-width: 640px) {
    .site-footer__top {
      grid-template-columns: 1fr 2fr;
    }
  }

  .site-footer__brand { display: flex; flex-direction: column; gap: 0.5rem; }
  .site-footer__name {
    font-size: 0.875rem;
    font-weight: 900;
    letter-spacing: -0.02em;
    color: var(--text);
  }
  .site-footer__desc {
    font-size: 0.75rem;
    color: var(--text-3);
    line-height: 1.6;
    max-width: 28ch;
  }

  .site-footer__cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  @media (max-width: 480px) {
    .site-footer__cols { grid-template-columns: 1fr 1fr; }
  }

  .site-footer__col-title {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-3);
    margin-bottom: 0.75rem;
  }
  .site-footer__col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }
  .site-footer__link {
    font-size: 0.8rem;
    color: var(--text-2);
    text-decoration: none;
    transition: color 0.15s;
  }
  .site-footer__link:hover { color: var(--accent); }
  .site-footer__src {
    font-size: 0.75rem;
    color: var(--text-3);
  }

  .site-footer__bottom {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border);
    font-size: 0.75rem;
    color: var(--text-3);
  }
  .site-footer__bottom-mid {
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }
</style>
