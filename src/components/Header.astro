---
import { SITE } from "$/config";
import SvgIcon from "./SvgIcon.astro";
import ModeSwitcherBtn from "./ModeSwitcherBtn.svelte";
import SearchBtn from "./SearchBtn.svelte";

const today = new Intl.DateTimeFormat("en-US", {
  weekday: "short", month: "short", day: "numeric", year: "numeric",
}).format(new Date());
---

<header class="site-header">
  <!-- ── Masthead row ── -->
  <div class="masthead">
    <a href="/" class="masthead__brand" title={SITE.name}>
      <img src="/logo.svg" alt="" class="masthead__logo" aria-hidden="true" />
      <span class="masthead__name">{SITE.name.toUpperCase()}</span>
    </a>
    <span class="masthead__rule" aria-hidden="true"></span>
    <div class="masthead__meta">
      <span class="masthead__date">{today}</span>
      <span class="masthead__dot" aria-hidden="true">·</span>
      <span class="masthead__tagline">AI · CS Research · Security</span>
    </div>
    <div class="masthead__actions">
      <SearchBtn client:visible />
      <a href={SITE.githubUrl} title="GitHub" class="icon-btn">
        <SvgIcon>
          <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
        </SvgIcon>
      </a>
      <a href="/rss.xml" title="RSS Feed" class="icon-btn">
        <SvgIcon>
          <path d="M4 11a9 9 0 0 1 9 9"></path>
          <path d="M4 4a16 16 0 0 1 16 16"></path>
          <circle cx="5" cy="19" r="1"></circle>
        </SvgIcon>
      </a>
      <ModeSwitcherBtn client:visible />
    </div>
  </div>
</header>

<style>
  .site-header {
    padding-top: 1rem;
    margin-bottom: 0;
  }

  /* ── Masthead ── */
  .masthead {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid var(--text);
    flex-wrap: wrap;
  }

  .masthead__brand {
    flex-shrink: 0;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .masthead__logo {
    width: 28px;
    height: 28px;
    flex-shrink: 0;
  }
  .masthead__name {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    color: var(--text);
    white-space: nowrap;
    line-height: 1;
  }
  .masthead__brand:hover .masthead__name { color: var(--accent); }

  .masthead__rule {
    flex: 1;
    height: 1px;
    background: var(--border);
    min-width: 2rem;
    display: none;
  }
  @media (min-width: 640px) { .masthead__rule { display: block; } }

  .masthead__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-2);
    flex: 1;
  }
  .masthead__date { color: var(--accent); font-weight: 600; white-space: nowrap; }
  .masthead__dot { color: var(--text-3); }
  .masthead__tagline { color: var(--text-3); }
  @media (max-width: 520px) { .masthead__tagline { display: none; } }

  .masthead__actions {
    display: flex;
    align-items: center;
    gap: 0.125rem;
    flex-shrink: 0;
    color: var(--text-3);
  }

  .icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 0.375rem;
    transition: background 0.15s, color 0.15s;
    text-decoration: none;
  }
  .icon-btn:hover {
    background: var(--bg-alt);
    color: var(--text);
  }
</style>
