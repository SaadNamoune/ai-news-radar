---
import { SITE } from "$/config";
import SvgIcon from "./SvgIcon.astro";
import ModeSwitcherBtn from "./ModeSwitcherBtn.svelte";
import SearchBtn from "./SearchBtn.svelte";

const todayLabel = new Intl.DateTimeFormat("en-US", {
  weekday: "short",
  month: "short",
  day: "numeric",
  year: "numeric",
}).format(new Date());
---

<header class="site-header">
  <div class="site-header__top">
    <a href="/" class="site-header__brand" title={SITE.name}>
      <div class="brand-icon" aria-hidden="true">
        <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg" width="36" height="36">
          <rect width="36" height="36" rx="8" fill="#0284c7"/>
          <text x="50%" y="56%" dominant-baseline="middle" text-anchor="middle"
            font-family="system-ui,sans-serif" font-weight="800" font-size="14"
            fill="white">AI</text>
        </svg>
      </div>
      <div class="brand-text">
        <span class="brand-name">{SITE.name}</span>
        <span class="brand-date">{todayLabel}</span>
      </div>
    </a>

    <div class="site-header__actions">
      <SearchBtn client:visible />
      <a href={SITE.githubUrl} title="GitHub" class="icon-btn">
        <SvgIcon>
          <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
        </SvgIcon>
      </a>
      <a href="/rss.xml" title="RSS Feed" class="icon-btn">
        <SvgIcon>
          <path d="M4 11a9 9 0 0 1 9 9"></path>
          <path d="M4 4a16 16 0 0 1 16 16"></path>
          <circle cx="5" cy="19" r="1"></circle>
        </SvgIcon>
      </a>
      <ModeSwitcherBtn client:visible />
    </div>
  </div>

  <p class="site-header__desc">{SITE.description}</p>
</header>

<style>
  .site-header {
    @apply pt-6 pb-4;
    border-bottom: 1px solid #e5e7eb;
  }
  html.dark .site-header { border-bottom-color: #1e293b; }

  .site-header__top {
    @apply flex items-center justify-between gap-3 mb-2;
  }

  .site-header__brand {
    @apply flex items-center gap-2.5 no-underline flex-1 min-w-0;
  }
  .brand-icon {
    @apply flex-none;
  }
  .brand-text {
    @apply flex flex-col min-w-0;
  }
  .brand-name {
    @apply font-extrabold text-lg leading-tight text-gray-900 dark:text-slate-50;
    letter-spacing: -0.02em;
  }
  .brand-date {
    @apply text-xs leading-tight;
    color: #94a3b8;
  }

  .site-header__actions {
    @apply flex items-center gap-0.5 flex-none;
    color: #9ca3af;
  }
  .icon-btn {
    @apply p-2 rounded-md transition-colors duration-150;
  }
  .icon-btn:hover {
    background: #f1f5f9;
    color: #374151;
  }
  html.dark .icon-btn:hover {
    background: #1e293b;
    color: #e2e8f0;
  }

  .site-header__desc {
    @apply text-sm;
    color: #6b7280;
  }
  html.dark .site-header__desc { color: #64748b; }

  /* Responsive: hide description on tiny screens */
  @media (max-width: 400px) {
    .site-header__desc { display: none; }
    .brand-date { display: none; }
  }
</style>
