---
import type { CollectionEntry } from "astro:content";
import { SITE } from "$/config";
import MainLayout from "$/components/MainLayout.astro";
import BaseHead from "$/components/BaseHead.astro";
import Prose from "$/components/Prose.astro";

interface Props {
  meta?: {
    id: string;
    slug: string;
    collection: string;
  };
  content: CollectionEntry<"blog">["data"];
  stats?: {
    views: number;
  };
}
const { content, meta } = Astro.props;

const formattedDate = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
}).format(new Date(content.date));

const tags = content.tags || [];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      {...content}
      title={content.title ? `${SITE.title} | ${content.title}` : SITE.title}
    />
  </head>
  <MainLayout>
    <article>
      <!-- Article header -->
      <div class="post-header">
        <div class="post-header__meta">
          <time class="post-header__date" datetime={content.date}>
            {formattedDate}
          </time>
          <span class="post-header__sep" aria-hidden="true">·</span>
          <span class="post-header__author">{SITE.author}</span>
        </div>

        <h1 class="post-header__title">{content.title}</h1>

        {
          tags.length > 0 && (
            <div class="post-header__tags">
              {tags.map((tag) => (
                <a class="post-header__tag" href={`/tags/${tag}`} title={tag}>
                  {tag}
                </a>
              ))}
            </div>
          )
        }

        <div class="post-header__divider" aria-hidden="true"></div>
      </div>

      {content.image && (
        <div class="post-cover">
          <img src={content.image} alt={content.title} />
        </div>
      )}

      <Prose>
        <slot />
      </Prose>
    </article>
  </MainLayout>
</html>

<style>
  /* Article header */
  .post-header {
    @apply pt-6 pb-2 mb-2;
  }
  .post-header__meta {
    @apply flex items-center gap-2 text-sm mb-3;
    color: #9ca3af;
  }
  html.dark .post-header__meta {
    color: #6b7280;
  }
  .post-header__date {
    font-variant-numeric: tabular-nums;
  }
  .post-header__sep {
    color: #d1d5db;
  }
  html.dark .post-header__sep {
    color: #374151;
  }
  .post-header__author {
    font-weight: 500;
    color: #6b7280;
  }
  html.dark .post-header__author {
    color: #9ca3af;
  }

  .post-header__title {
    @apply text-3xl md:text-4xl font-black leading-tight mb-4 tracking-tight;
    background: linear-gradient(135deg, #6366f1 0%, #a855f7 60%, #06b6d4 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .post-header__tags {
    @apply flex flex-wrap gap-2 mb-4;
  }
  .post-header__tag {
    @apply px-2.5 py-1 rounded-full text-xs font-semibold no-underline transition-colors duration-150;
    background: rgba(99, 102, 241, 0.08);
    color: #6366f1;
    border: 1px solid rgba(99, 102, 241, 0.15);
  }
  html.dark .post-header__tag {
    background: rgba(129, 140, 248, 0.1);
    color: #a5b4fc;
    border-color: rgba(129, 140, 248, 0.18);
  }
  .post-header__tag:hover {
    background: rgba(99, 102, 241, 0.15);
  }
  html.dark .post-header__tag:hover {
    background: rgba(129, 140, 248, 0.18);
  }

  .post-header__divider {
    @apply mt-2 rounded-full;
    height: 2px;
    background: linear-gradient(90deg, #6366f1, #a855f7, transparent);
    max-width: 240px;
    opacity: 0.5;
  }

  /* Cover image */
  .post-cover {
    @apply mb-6 rounded-2xl overflow-hidden;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.1);
  }
  html.dark .post-cover {
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.4);
  }
  .post-cover img {
    @apply w-full object-cover max-h-80;
  }
</style>
