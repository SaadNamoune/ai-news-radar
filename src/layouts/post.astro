---
import type { CollectionEntry } from "astro:content";
import { SITE } from "$/config";
import MainLayout from "$/components/MainLayout.astro";
import BaseHead from "$/components/BaseHead.astro";
import Prose from "$/components/Prose.astro";

interface Props {
  meta?: {
    id: string;
    slug: string;
    collection: string;
  };
  content: CollectionEntry<"blog">["data"];
}
const { content } = Astro.props;

const formattedDate = new Intl.DateTimeFormat("en-US", {
  weekday: "long",
  year: "numeric",
  month: "long",
  day: "numeric",
}).format(new Date(content.date));

const tags = content.tags || [];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      {...content}
      title={content.title ? `${SITE.title} | ${content.title}` : SITE.title}
    />
  </head>
  <MainLayout>
    <article class="post-article">
      <!-- Article header -->
      <header class="post-article__header">
        <div class="post-article__kicker">
          <span class="post-article__label">Daily Digest</span>
          <span class="post-article__sep">·</span>
          <time class="post-article__date" datetime={content.date}>{formattedDate}</time>
        </div>

        <h1 class="post-article__title">{content.title}</h1>

        <div class="post-article__meta">
          <span class="post-article__author">By {SITE.author}</span>
          {
            tags.length > 0 && (
              <>
                <span class="post-article__sep">·</span>
                <div class="post-article__tags">
                  {tags.slice(0, 6).map((tag) => (
                    <a class="post-article__tag" href={`/tags/${tag}`}>{tag}</a>
                  ))}
                </div>
              </>
            )
          }
        </div>
      </header>

      {content.image && (
        <figure class="post-article__cover">
          <img src={content.image} alt={content.title} loading="lazy" />
        </figure>
      )}

      <Prose>
        <slot />
      </Prose>
    </article>
  </MainLayout>
</html>

<style>
  .post-article { @apply py-2; }

  /* Kicker / breadcrumb row */
  .post-article__header { @apply mb-6 pt-4; }
  .post-article__kicker {
    @apply flex items-center gap-2 text-xs font-medium mb-3;
    color: #0284c7;
  }
  html.dark .post-article__kicker { color: #38bdf8; }
  .post-article__label {
    @apply uppercase tracking-wider font-bold;
  }
  .post-article__sep { color: #cbd5e1; }
  html.dark .post-article__sep { color: #334155; }
  .post-article__date { color: #64748b; font-weight: 400; }
  html.dark .post-article__date { color: #475569; }

  /* Title */
  .post-article__title {
    @apply font-extrabold leading-tight mb-4;
    font-size: clamp(1.5rem, 4vw, 2rem);
    letter-spacing: -0.025em;
    color: #0f172a;
  }
  html.dark .post-article__title { color: #f8fafc; }

  /* Meta row */
  .post-article__meta {
    @apply flex flex-wrap items-center gap-2 text-sm;
    color: #94a3b8;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid #e5e7eb;
  }
  html.dark .post-article__meta { border-bottom-color: #1e293b; }
  .post-article__author { font-weight: 500; color: #6b7280; }
  html.dark .post-article__author { color: #64748b; }

  /* Tags */
  .post-article__tags { @apply flex flex-wrap gap-1.5; }
  .post-article__tag {
    @apply text-xs px-2 py-0.5 rounded-full no-underline transition-colors duration-150;
    background: #f0f9ff;
    color: #0284c7;
    border: 1px solid #bae6fd;
    font-family: 'SFMono-Regular', Consolas, Menlo, monospace;
  }
  html.dark .post-article__tag {
    background: rgba(2, 132, 199, 0.08);
    color: #38bdf8;
    border-color: #0369a1;
  }
  .post-article__tag:hover { background: #e0f2fe; }
  html.dark .post-article__tag:hover { background: rgba(2, 132, 199, 0.15); }

  /* Cover image */
  .post-article__cover {
    @apply mb-6 rounded-lg overflow-hidden;
    border: 1px solid #e5e7eb;
  }
  html.dark .post-article__cover { border-color: #1e293b; }
  .post-article__cover img {
    @apply w-full object-cover max-h-72;
  }

  /* Responsive title */
  @media (max-width: 480px) {
    .post-article__meta { @apply flex-col items-start gap-1.5; }
  }
</style>
