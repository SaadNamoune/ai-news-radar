---
import type { CollectionEntry } from "astro:content";
import { SITE } from "$/config";
import MainLayout from "$/components/MainLayout.astro";
import BaseHead from "$/components/BaseHead.astro";
import Prose from "$/components/Prose.astro";

interface Props {
  meta?: { id: string; slug: string; collection: string };
  content: CollectionEntry<"blog">["data"];
}

const { content } = Astro.props;

const tags = content.tags || [];
const date = new Date(content.date);

const longDate = new Intl.DateTimeFormat("en-US", {
  weekday: "long", year: "numeric", month: "long", day: "numeric",
}).format(date);

const shortDate = new Intl.DateTimeFormat("en-US", {
  month: "short", day: "2-digit", year: "numeric",
}).format(date);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      {...content}
      title={content.title ? `${SITE.title} | ${content.title}` : SITE.title}
    />
  </head>
  <MainLayout>
    <article class="post-wrap">

      <!-- ── Top meta bar ── -->
      <div class="post-meta-bar">
        <span class="post-label">DAILY DIGEST</span>
        <time class="post-meta-date" datetime={content.date}>{longDate}</time>
        <span class="post-meta-sep">·</span>
        <a href="/blog" class="post-meta-link">All issues</a>
      </div>

      <!-- ── Title ── -->
      <h1 class="post-title">{content.title}</h1>

      <!-- ── Two-column body ── -->
      <div class="post-layout">

        <!-- Main content column -->
        <div class="post-content">
          {content.image && (
            <figure class="post-cover">
              <img src={content.image} alt={content.title} loading="lazy" />
            </figure>
          )}
          <Prose>
            <slot />
          </Prose>
        </div>

        <!-- Sidebar -->
        <aside class="post-sidebar">

          <div class="sidebar-card">
            <div class="sidebar-card__label">Issue Info</div>
            <div class="sidebar-info-row">
              <span class="sidebar-info-key">Date</span>
              <span class="sidebar-info-val">{shortDate}</span>
            </div>
            <div class="sidebar-info-row">
              <span class="sidebar-info-key">Author</span>
              <span class="sidebar-info-val">{SITE.author}</span>
            </div>
          </div>

          {tags.length > 0 && (
            <div class="sidebar-card">
              <div class="sidebar-card__label">Topics</div>
              <div class="sidebar-tags">
                {tags.map(tag => (
                  <a href={`/tags/${tag}`} class="sidebar-tag">{tag}</a>
                ))}
              </div>
            </div>
          )}

          <div class="sidebar-card sidebar-nav-links">
            <a href="/blog" class="sidebar-link">← All issues</a>
            <a href="/rss.xml" class="sidebar-link">Subscribe via RSS</a>
          </div>

        </aside>
      </div>

    </article>
  </MainLayout>
</html>

<style>
  .post-wrap {
    padding-top: 0.75rem;
    padding-bottom: 3rem;
  }

  /* ── Top meta bar ── */
  .post-meta-bar {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }
  .post-label {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-bg);
    border: 1px solid var(--accent);
    padding: 0.2em 0.6em;
    border-radius: 0.2rem;
  }
  .post-meta-date {
    font-size: 0.78rem;
    color: var(--text-2);
    font-weight: 500;
  }
  .post-meta-sep { color: var(--text-3); font-size: 0.75rem; }
  .post-meta-link {
    font-size: 0.78rem;
    color: var(--accent);
    text-decoration: none;
    font-weight: 600;
  }
  .post-meta-link:hover { text-decoration: underline; }

  /* ── Title ── */
  .post-title {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 900;
    letter-spacing: -0.035em;
    line-height: 1.1;
    color: var(--text);
    margin-bottom: 1.25rem;
  }

  /* ── Two-column layout ── */
  .post-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: start;
  }
  @media (min-width: 768px) {
    .post-layout {
      grid-template-columns: 1fr 220px;
    }
  }
  @media (min-width: 1024px) {
    .post-layout {
      grid-template-columns: 1fr 240px;
    }
  }

  /* ── Cover image ── */
  .post-cover {
    margin-bottom: 1.5rem;
    border-radius: 0.5rem;
    overflow: hidden;
    border: 1px solid var(--border);
  }
  .post-cover img {
    width: 100%;
    max-height: 320px;
    object-fit: cover;
    display: block;
  }

  /* ── Sidebar ── */
  .post-sidebar {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  @media (min-width: 768px) {
    .post-sidebar {
      position: sticky;
      top: 1.5rem;
    }
  }

  .sidebar-card {
    background: var(--bg-alt);
    border: 1px solid var(--border);
    border-radius: 0.375rem;
    padding: 0.875rem 1rem;
  }
  .sidebar-card__label {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-3);
    margin-bottom: 0.625rem;
  }

  .sidebar-info-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: 0.75rem;
    padding: 0.2rem 0;
    border-bottom: 1px solid var(--border-alt);
  }
  .sidebar-info-row:last-child { border-bottom: none; }
  .sidebar-info-key { color: var(--text-3); }
  .sidebar-info-val { color: var(--text-2); font-weight: 600; }

  .sidebar-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }
  .sidebar-tag {
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.2em 0.55em;
    border-radius: 0.2rem;
    background: var(--bg-card);
    color: var(--text-3);
    border: 1px solid var(--border);
    text-decoration: none;
    font-family: 'SFMono-Regular', Consolas, Menlo, monospace;
    transition: color 0.15s, border-color 0.15s;
  }
  .sidebar-tag:hover { color: var(--accent); border-color: var(--accent); }

  .sidebar-nav-links {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .sidebar-link {
    font-size: 0.78rem;
    color: var(--accent);
    text-decoration: none;
    font-weight: 600;
    transition: opacity 0.15s;
  }
  .sidebar-link:hover { opacity: 0.75; }
</style>
